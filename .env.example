# RedRainbow - Environment Configuration
# --------------------------------------------------

# CORE: Security & AI
JWT_SECRET=SUPER_SECRET_CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
GEMINI_API_KEY=your_gemini_api_key_here

# DATABASE: URLs (Internal Docker Networking)
DATABASE_URL=mysql+pymysql://appuser:MySqlApp!2025#Secure@red-db:3306/redrainbow_appdb
MONGODB_URL=mongodb://admin:Mongo!2025#Secure@red-mongo:27017/appdb?authSource=admin
REDIS_URL=redis://:Redis!2025#Secure@redis:6379/0

# DATABASE: Credentials for Docker Compose
MYSQL_DATABASE=redrainbow_appdb
MYSQL_USER=appuser
MYSQL_PASSWORD=MySqlApp!2025#Secure
MYSQL_ROOT_PASSWORD=RootPassword!2025

# DATABASE: MongoDB (Document/Logs)
MONGO_DATABASE=appdb
MONGO_USER=admin
MONGO_PASSWORD=Mongo!2025#Secure

# CACHE: Redis
REDIS_PASSWORD=Redis!2025#Secure

# INFRA: Mesh Performance
REGISTRATION_INVITE_CODE=RR-MASTER-2025
RATE_LIMIT_PER_MINUTE=60
MESH_DEBUG=false
